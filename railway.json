{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "nixpacks": {
      "pkgs": ["python3", "pip"],
      "install": ["pip install -r requirements.txt"]
    }
  },
  "deploy": {
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "startCommand": "gunicorn --bind 0.0.0.0:$PORT --workers 1 --worker-class gevent --worker-connections 1000 --threads 4 app:app"
  },
  "disk": {
    "mountPoint": "/var/data",
    "size": 256
  }
}
